     1	/**
     2	 * Auth initialization: JWT secret management, users.json migration, auth config loading.
     3	 *
     4	 * CRITICAL: JWT secret is stored in data/jwt-secret.txt — NEVER in public/settings.yaml.
     5	 * The public/ directory is served statically to clients by Express.
     6	 */
     7	
     8	import crypto from 'node:crypto';
     9	import fs from 'node:fs';
    10	import path from 'node:path';
    11	
    12	import bcrypt from 'bcryptjs';
    13	
    14	import { initKeycloakAuth } from './keycloakAuth.js';
    15	
    16	// ---------------------------------------------------------------------------
    17	// Types
    18	// ---------------------------------------------------------------------------
    19	
    20	export interface UserRecord {
    21	  username: string;
    22	  passwordHash?: string;
    23	  role: string;
    24	  centers: string[];
    25	  firstName?: string;
    26	  lastName?: string;
    27	  createdAt: string;
    28	  lastLogin?: string;
    29	}
    30	
    31	interface AuthConfig {
    32	  twoFactorEnabled: boolean;
    33	  maxLoginAttempts: number;
    34	  otpCode: string;
    35	}
    36	
    37	// ---------------------------------------------------------------------------
    38	// Module-level state (populated by initAuth)
    39	// ---------------------------------------------------------------------------
    40	
    41	let _jwtSecret: string | null = null;
    42	let _authConfig: AuthConfig | null = null;
    43	let _usersFile: string | null = null;
    44	
    45	// ---------------------------------------------------------------------------
    46	// Public API
    47	// ---------------------------------------------------------------------------
    48	
    49	/**
    50	 * Called once at startup. Loads or generates JWT secret, migrates users.json,
    51	 * and parses auth config from settings.
    52	 *
    53	 * JWT secret is stored in data/jwt-secret.txt (NOT in public/settings.yaml).
    54	 */
    55	export function initAuth(dataDir: string, settings: Record<string, unknown>): void {
    56	  const secretFile = path.join(dataDir, 'jwt-secret.txt');
    57	  _usersFile = path.join(dataDir, 'users.json');
    58	
    59	  // Load or generate JWT secret
    60	  if (fs.existsSync(secretFile)) {
    61	    _jwtSecret = fs.readFileSync(secretFile, 'utf-8').trim();
    62	    if (!_jwtSecret) {
    63	      throw new Error('[initAuth] jwt-secret.txt exists but is empty — delete it to regenerate');
    64	    }
    65	  } else {
    66	    _jwtSecret = crypto.randomBytes(32).toString('hex');
    67	    fs.writeFileSync(secretFile, _jwtSecret, { encoding: 'utf-8', mode: 0o600 });
    68	    console.log(`[initAuth] Generated new JWT secret at ${secretFile}`);
    69	  }
    70	
    71	  // Parse auth config from flat settings structure (F-10: consistent with validator)
    72	  _authConfig = {
    73	    twoFactorEnabled: typeof settings.twoFactorEnabled === 'boolean' ? settings.twoFactorEnabled : false,
    74	    maxLoginAttempts: typeof settings.maxLoginAttempts === 'number' ? settings.maxLoginAttempts : 5,
    75	    otpCode: typeof settings.otpCode === 'string' ? settings.otpCode : '123456',
    76	  };
    77	
    78	  // Parse auth provider and initialize Keycloak if needed
    79	  const provider = typeof settings.provider === 'string' ? settings.provider : 'local';
    80	  if (provider === 'keycloak') {
    81	    const kc = (settings.keycloak ?? {}) as Record<string, unknown>;
    82	    if (typeof kc.issuer !== 'string' || !kc.issuer) {
    83	      throw new Error('[initAuth] keycloak.issuer is required when provider=keycloak');
    84	    }
    85	    initKeycloakAuth(kc.issuer);
    86	    console.log(`[initAuth] Keycloak mode enabled. JWKS: ${kc.issuer}/protocol/openid-connect/certs`);
    87	  }
    88	
    89	  // Migrate users.json: add bcrypt passwordHash for any user missing it
    90	  if (fs.existsSync(_usersFile)) {
    91	    _migrateUsersJson(_usersFile);
    92	  }
    93	}
    94	
    95	/**
    96	 * Returns the loaded JWT secret.
    97	 * Throws if initAuth() has not been called.
    98	 */
    99	export function getJwtSecret(): string {
   100	  if (_jwtSecret === null) {
   101	    throw new Error('[initAuth] getJwtSecret() called before initAuth()');
   102	  }
   103	  return _jwtSecret;
   104	}
   105	
   106	/**
   107	 * Returns the parsed auth configuration.
   108	 * Throws if initAuth() has not been called.
   109	 */
   110	export function getAuthConfig(): AuthConfig {
   111	  if (_authConfig === null) {
   112	    throw new Error('[initAuth] getAuthConfig() called before initAuth()');
   113	  }
   114	  return _authConfig;
   115	}
   116	
   117	/**
   118	 * Re-parse auth config from updated settings.
   119	 * Called after settings.yaml is written so the in-memory config stays in sync.
   120	 */
   121	export function updateAuthConfig(settings: Record<string, unknown>): void {
   122	  _authConfig = {
   123	    twoFactorEnabled: typeof settings.twoFactorEnabled === 'boolean' ? settings.twoFactorEnabled : false,
   124	    maxLoginAttempts: typeof settings.maxLoginAttempts === 'number' ? settings.maxLoginAttempts : 5,
   125	    otpCode: typeof settings.otpCode === 'string' ? settings.otpCode : '123456',
   126	  };
   127	}
   128	
   129	/**
   130	 * Reads and returns all users from data/users.json.
   131	 * Throws if initAuth() has not been called or users file does not exist.
   132	 */
   133	export function loadUsers(): UserRecord[] {
   134	  if (_usersFile === null) {
   135	    throw new Error('[initAuth] loadUsers() called before initAuth()');
   136	  }
   137	  if (!fs.existsSync(_usersFile)) {
   138	    return [];
   139	  }
   140	  const raw = fs.readFileSync(_usersFile, 'utf-8');
   141	  return JSON.parse(raw) as UserRecord[];
   142	}
   143	
   144	// ---------------------------------------------------------------------------
   145	// Write serialization
   146	// ---------------------------------------------------------------------------
   147	
   148	/**
   149	 * In-process write lock to serialize user-write operations.
   150	 * Prevents lost-update race when two admin requests overlap.
   151	 * (Review concern #8: concurrent admin mutations)
   152	 */
   153	let _writeLock = false;
   154	const _writeQueue: Array<() => void> = [];
   155	
   156	function acquireWriteLock(): Promise<void> {
   157	  return new Promise((resolve) => {
   158	    if (!_writeLock) {
   159	      _writeLock = true;
   160	      resolve();
   161	    } else {
   162	      _writeQueue.push(resolve);
   163	    }
   164	  });
   165	}
   166	
   167	function releaseWriteLock(): void {
   168	  const next = _writeQueue.shift();
   169	  if (next) {
   170	    next();
   171	  } else {
   172	    _writeLock = false;
   173	  }
   174	}
   175	
   176	/**
   177	 * Atomically write the full user list to data/users.json.
   178	 * Uses temp-file + rename to prevent corruption on crash.
   179	 * Write operations are serialized to prevent lost updates
   180	 * from concurrent admin requests.
   181	 */
   182	export async function saveUsers(users: UserRecord[]): Promise<void> {
   183	  if (_usersFile === null) {
   184	    throw new Error('[initAuth] saveUsers() called before initAuth()');
   185	  }
   186	  await acquireWriteLock();
   187	  try {
   188	    _atomicWrite(_usersFile, JSON.stringify(users, null, 2));
   189	  } finally {
   190	    releaseWriteLock();
   191	  }
   192	}
   193	
   194	/**
   195	 * F-11: Execute a read-modify-write cycle under the write lock.
   196	 * Prevents TOCTOU races where concurrent admin requests read stale data.
   197	 * The callback receives the current users array and must return the updated array.
   198	 */
   199	export async function modifyUsers(fn: (users: UserRecord[]) => UserRecord[]): Promise<UserRecord[]> {
   200	  if (_usersFile === null) {
   201	    throw new Error('[initAuth] modifyUsers() called before initAuth()');
   202	  }
   203	  await acquireWriteLock();
   204	  try {
   205	    const users = loadUsers();
   206	    const updated = fn(users);
   207	    _atomicWrite(_usersFile, JSON.stringify(updated, null, 2));
   208	    return updated;
   209	  } finally {
   210	    releaseWriteLock();
   211	  }
   212	}
   213	
   214	// ---------------------------------------------------------------------------
   215	// Internal helpers
   216	// ---------------------------------------------------------------------------
   217	
   218	/**
   219	 * Atomic write: write to temp file then rename.
   220	 */
   221	function _atomicWrite(filePath: string, content: string): void {
   222	  const tmp = `${filePath}.tmp.${Date.now()}`;
   223	  fs.writeFileSync(tmp, content, 'utf-8');
   224	  fs.renameSync(tmp, filePath);
   225	}
   226	
   227	// ---------------------------------------------------------------------------
   228	// Center ID migration
   229	// ---------------------------------------------------------------------------
   230	
   231	/**
   232	 * Mapping from shorthand center names to org-* format.
   233	 * Shorthand values are legacy and must be migrated at startup.
   234	 */
   235	const SHORTHAND_TO_ORG: Record<string, string> = {
   236	  'UKA':  'org-uka',
   237	  'UKC':  'org-ukc',
   238	  'UKD':  'org-ukd',
   239	  'UKG':  'org-ukg',
   240	  'UKL':  'org-ukl',
   241	  'UKMZ': 'org-ukmz',
   242	  'UKT':  'org-ukt',
   243	};
   244	
   245	/**
   246	 * Migrate center IDs from shorthand (e.g. "UKA") to org-* format (e.g. "org-uka").
   247	 * Already-migrated values (org-*) are left unchanged.
   248	 *
   249	 * Exported for testing.
   250	 */
   251	export function _migrateCenterIds(users: UserRecord[]): { users: UserRecord[]; changed: boolean } {
   252	  let changed = false;
   253	  const migrated = users.map((u) => {
   254	    const newCenters = u.centers.map((c) => SHORTHAND_TO_ORG[c] ?? c);
   255	    if (newCenters.some((nc, i) => nc !== u.centers[i])) changed = true;
   256	    return { ...u, centers: newCenters };
   257	  });
   258	  return { users: migrated, changed };
   259	}
   260	
   261	/**
   262	 * Set of removed center IDs (v1.0/v1.1 roster).
   263	 * v1.5 roster correction removes Bonn (org-ukb), München (org-lmu), Münster (org-ukm).
   264	 * Users holding only these centers are reassigned to ['org-uka'] (default fallback)
   265	 * so they remain functional after the roster switch.
   266	 *
   267	 * Exported indirectly via _migrateRemovedCenters for testing.
   268	 */
   269	const REMOVED_CENTER_IDS = new Set<string>(['org-ukb', 'org-lmu', 'org-ukm']);
   270	
   271	/**
   272	 * Strip removed-roster center IDs from each user's centers array.
   273	 * Users whose centers array becomes empty after stripping are reassigned to ['org-uka'].
   274	 *
   275	 * Exported for testing.
   276	 */
   277	export function _migrateRemovedCenters(
   278	  users: UserRecord[],
   279	): { users: UserRecord[]; changed: boolean } {
   280	  let changed = false;
   281	  const migrated = users.map((u) => {
   282	    const filtered = u.centers.filter((c) => !REMOVED_CENTER_IDS.has(c));
   283	    const dropped = filtered.length !== u.centers.length;
   284	    if (filtered.length === 0) {
   285	      changed = true;
   286	      return { ...u, centers: ['org-uka'] };
   287	    }
   288	    if (dropped) {
   289	      changed = true;
   290	      return { ...u, centers: filtered };
   291	    }
   292	    return u;
   293	  });
   294	  return { users: migrated, changed };
   295	}
   296	
   297	/**
   298	 * Migrate users.json: add passwordHash for any user missing it,
   299	 * and convert center IDs from shorthand to org-* format.
   300	 * Uses bcrypt with 12 rounds and the default password 'changeme2025!'.
   301	 */
   302	function _migrateUsersJson(filePath: string): void {
   303	  const raw = fs.readFileSync(filePath, 'utf-8');
   304	  const users = JSON.parse(raw) as UserRecord[];
   305	
   306	  let needsWrite = false;
   307	  let workingUsers = users;
   308	
   309	  // Migrate password hashes
   310	  const withHashes = workingUsers.map((user) => {
   311	    if (!user.passwordHash) {
   312	      needsWrite = true;
   313	      const hash = bcrypt.hashSync('changeme2025!', 12); // sync OK at startup (one-time migration)
   314	      return { ...user, passwordHash: hash };
   315	    }
   316	    return user;
   317	  });
   318	
   319	  if (needsWrite) {
   320	    console.log('[initAuth] Migrated users.json: added bcrypt passwordHash for users without one');
   321	  }
   322	
   323	  workingUsers = withHashes;
   324	
   325	  // Migrate center IDs from shorthand to org-* format
   326	  const { users: withOrgCenters, changed } = _migrateCenterIds(workingUsers);
   327	  if (changed) {
   328	    needsWrite = true;
   329	    workingUsers = withOrgCenters;
   330	    console.log('[initAuth] Migrated users.json: converted center IDs to org-* format');
   331	  }
   332	
   333	  // Migrate removed center IDs (v1.5 roster correction)
   334	  // Must run AFTER _migrateCenterIds so legacy shorthand-form centers have
   335	  // already been promoted to org-* before we check for removed IDs.
   336	  const { users: withoutRemoved, changed: removedChanged } = _migrateRemovedCenters(workingUsers);
   337	  if (removedChanged) {
   338	    needsWrite = true;
   339	    workingUsers = withoutRemoved;
   340	    console.log('[initAuth] Migrated users.json: stripped removed center IDs (org-ukb/org-lmu/org-ukm)');
   341	  }
   342	
   343	  if (needsWrite) {
   344	    _atomicWrite(filePath, JSON.stringify(workingUsers, null, 2));
   345	  }
   346	}

