     2	 * JWT authentication middleware for Express.
     3	 *
     4	 * Validates Bearer tokens on all /api/* routes, excluding public auth paths.
     5	 * Branches on auth provider:
     6	 *   - local: HS256 validation using local JWT secret (existing behavior unchanged)
     7	 *   - keycloak: RS256 validation via JWKS endpoint (T-06-01, T-06-02)
     8	 *
     9	 * Challenge-purpose tokens are rejected on protected routes (T-02-02).
    10	 * Keycloak unavailability returns 503 fail-closed (D-03, T-06-05).
    11	 */
    12	
    13	import type { NextFunction,Request, Response } from 'express';
    14	import jwt from 'jsonwebtoken';
    15	
    16	import { getJwtSecret } from './initAuth.js';
    17	import { getAuthProvider, getJwksClient } from './keycloakAuth.js';
    18	
    19	// ---------------------------------------------------------------------------
    20	// Types
    21	// ---------------------------------------------------------------------------
    22	
    23	export interface AuthPayload {
    24	  sub: string;
    25	  preferred_username: string;
    26	  role: string;
    27	  centers: string[];
    28	  purpose?: string;
    29	  iat: number;
    30	  exp: number;
    31	}
    32	
    33	// F-17: Single declaration — all server files import authMiddleware transitively
    34	declare global {
    35	  // eslint-disable-next-line @typescript-eslint/no-namespace
    36	  namespace Express {
    37	    interface Request {
    38	      auth?: AuthPayload;
    39	    }
    40	  }
    41	}
    42	
    43	// ---------------------------------------------------------------------------
    44	// Public paths (no JWT required)
    45	// ---------------------------------------------------------------------------
    46	
    47	const PUBLIC_PATHS = ['/api/auth/login', '/api/auth/verify', '/api/auth/config'];
    48	
    49	// ---------------------------------------------------------------------------
    50	// Local HS256 verification (existing behavior)
    51	// ---------------------------------------------------------------------------
    52	
    53	/**
    54	 * Verify a local HS256 JWT and populate req.auth.
    55	 * Rejects challenge-purpose tokens (T-02-02).
    56	 */
    57	function verifyLocalToken(token: string, req: Request, res: Response, next: NextFunction): void {
    58	  try {
    59	    const payload = jwt.verify(token, getJwtSecret()) as AuthPayload;
    60	    if (payload.purpose === 'challenge') {
    61	      res.status(401).json({ error: 'Challenge tokens cannot be used for authentication' });
    62	      return;
    63	    }
    64	    req.auth = payload;
    65	    next();
    66	  } catch {
    67	    res.status(401).json({ error: 'Invalid or expired token' });
    68	  }
    69	}
    70	
    71	// ---------------------------------------------------------------------------
    72	// Keycloak RS256 JWKS verification
    73	// ---------------------------------------------------------------------------
    74	
    75	/**
    76	 * Verify a Keycloak RS256 JWT via JWKS endpoint and populate req.auth.
    77	 *
    78	 * Security behaviors:
    79	 * - 503 when JWKS client not initialized (D-03 fail-closed)
    80	 * - 401 when token has no kid header (T-06-01 algorithm confusion prevention)
    81	 * - Explicit algorithms: ['RS256'] to prevent algorithm confusion attacks (T-06-01)
    82	 * - 503 on ECONNREFUSED/ENOTFOUND (D-03 fail-closed, T-06-05)
    83	 * - Claim normalization: role array->string, centers string->array (T-06-03)
    84	 * - Rejects challenge-purpose tokens (T-02-02)
    85	 */
    86	async function verifyKeycloakToken(token: string, req: Request, res: Response, next: NextFunction): Promise<void> {
    87	  const client = getJwksClient();
    88	  if (!client) {
    89	    res.status(503).json({ error: 'Keycloak auth not initialized' });
    90	    return;
    91	  }
    92	
    93	  try {
    94	    const decoded = jwt.decode(token, { complete: true });
    95	    if (!decoded || typeof decoded === 'string' || !decoded.header.kid) {
    96	      res.status(401).json({ error: 'Token missing key ID (kid)' });
    97	      return;
    98	    }
    99	
   100	    const signingKey = await client.getSigningKey(decoded.header.kid);
   101	    const raw = jwt.verify(token, signingKey.getPublicKey(), {
   102	      algorithms: ['RS256'],
   103	    }) as Record<string, unknown>;
   104	
   105	    // Reject challenge-purpose tokens (T-02-02)
   106	    if (raw.purpose === 'challenge') {
   107	      res.status(401).json({ error: 'Challenge tokens cannot be used for authentication' });
   108	      return;
   109	    }
   110	
   111	    // Normalize claims: Keycloak may return role as array, centers as single string (T-06-03)
   112	    const rawRole = Array.isArray(raw.role) ? (raw.role as string[])[0] : (raw.role as string);
   113	    const rawCenters = Array.isArray(raw.centers)
   114	      ? (raw.centers as string[])
   115	      : typeof raw.centers === 'string' ? [raw.centers as string] : [];
   116	
   117	    req.auth = {
   118	      sub: raw.sub as string,
   119	      preferred_username: raw.preferred_username as string,
   120	      role: rawRole,
   121	      centers: rawCenters,
   122	      iat: raw.iat as number,
   123	      exp: raw.exp as number,
   124	    };
   125	    next();
   126	  } catch (err: unknown) {
   127	    const msg = err instanceof Error ? err.message : '';
   128	    if (msg.includes('ECONNREFUSED') || msg.includes('ENOTFOUND') || msg.includes('network')) {
   129	      res.status(503).json({ error: 'Keycloak is unreachable. Contact your administrator.' });
   130	    } else {
   131	      res.status(401).json({ error: 'Invalid or expired token' });
   132	    }
   133	  }
   134	}
   135	
   136	// ---------------------------------------------------------------------------
   137	// Middleware
   138	// ---------------------------------------------------------------------------
   139	
   140	/**
   141	 * Validates JWT Bearer tokens on all routes.
   142	 * Skips validation for PUBLIC_PATHS.
   143	 * Branches on provider: local (HS256) or keycloak (RS256 via JWKS).
   144	 *
   145	 * Uses req.originalUrl (not req.path) for reliable matching when middleware
   146	 * is mounted on a sub-path (addresses review concern #6).
   147	 */
   148	export async function authMiddleware(req: Request, res: Response, next: NextFunction): Promise<void> {
   149	  // Use req.originalUrl for reliable matching (review concern #6)
   150	  const urlPath = req.originalUrl.split('?')[0];
   151	
   152	  if (PUBLIC_PATHS.includes(urlPath)) {
   153	    next();
   154	    return;
   155	  }
   156	
   157	  const header = req.headers.authorization;
   158	  if (!header?.startsWith('Bearer ')) {
   159	    res.status(401).json({ error: 'Authentication required' });
   160	    return;
   161	  }
   162	
   163	  const token = header.slice(7);
   164	  const provider = getAuthProvider();
   165	
   166	  if (provider === 'keycloak') {
   167	    await verifyKeycloakToken(token, req, res, next);
   168	  } else {
   169	    verifyLocalToken(token, req, res, next);
   170	  }
   171	}

