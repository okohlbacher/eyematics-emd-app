   131	    const urlPath = req.originalUrl.split('?')[0];
   132	
   133	    // Phase 11 / D-10 / T-11-01: skip paths whose handlers write their own audit row.
   134	    // This check MUST precede body capture so the raw body is never read/serialised here.
   135	    if (SKIP_AUDIT_PATHS.has(urlPath)) return;
   136	
   137	    const duration = Date.now() - startMs;
   138	    // req.auth is populated by authMiddleware for authenticated requests;
   139	    // undefined for requests that were rejected (401) — fall back to 'anonymous'
   140	    const user = req.auth?.preferred_username ?? 'anonymous';
   141	
   142	    // Per D-11: mutations log (redacted) body; GETs log query params only
   143	    // Body capture priority (Bug 1 fix):
   144	    //   1. req.body (from express.json()) — populated for /api/auth/* routes
   145	    //   2. req._capturedBody (from readBody()) — populated for all other mutation routes
   146	    // _capturedBody is always a raw string. tryParseJson attempts JSON parse so
   147	    // redactBody can walk REDACT_PATHS for object bodies; YAML bodies stay as
   148	    // raw strings and redactBody handles them via its String(body) fallback.
   149	    const rawBody = req.method !== 'GET'
   150	      ? (req.body !== undefined && req.body !== null
   151	          ? req.body
   152	          : (req._capturedBody ? tryParseJson(req._capturedBody) : undefined))
   153	      : undefined;
   154	    const bodyStr = req.method !== 'GET' ? redactBody(urlPath, rawBody) : null;
   155	    const queryStr =
   156	      req.method === 'GET' && Object.keys(req.query).length > 0
   157	        ? JSON.stringify(req.query)
   158	        : null;
   159	
   160	    logAuditEntry({
   161	      id: crypto.randomUUID(),
   162	      timestamp: new Date().toISOString(),
   163	      method: req.method,
   164	      path: urlPath,
   165	      user,
   166	      status: res.statusCode,
   167	      duration_ms: duration,
   168	      body: bodyStr,
   169	      query: queryStr,
   170	    });
   171	  });
   172	
   173	  next();
   174	}

codex
I found another operational dependency hidden in the current implementation: several write endpoints validate case IDs against an in-memory case index, but that index stays empty until FHIR bundles are loaded on demand. Because startup cache warming was never wired, those writes can fail on a cold server even for authorized users.
