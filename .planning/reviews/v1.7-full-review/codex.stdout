    88	    if (filters.centers?.length && !filters.centers.includes(c.centerId)) return false;
    89	    if (filters.gender?.length && !filters.gender.includes(c.gender)) return false;
    90	    if (filters.diagnosis?.length) {
    91	      const codes = c.conditions.flatMap((cond) => cond.code.coding.map((cd) => cd.code));
    92	      if (!filters.diagnosis.some((d) => codes.includes(d))) return false;
    93	    }
    94	    if (filters.ageRange) {
    95	      const age = getAge(c.birthDate);
    96	      if (age < filters.ageRange[0] || age > filters.ageRange[1]) return false;
    97	    }
