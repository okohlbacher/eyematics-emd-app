    74	
    75	export function getAge(birthDate: string): number {
    76	  if (!birthDate) return -1;
    77	  const birth = new Date(birthDate);
    78	  if (isNaN(birth.getTime())) return -1;
    79	  const now = new Date();
    80	  let age = now.getFullYear() - birth.getFullYear();
    81	  const m = now.getMonth() - birth.getMonth();
    82	  if (m < 0 || (m === 0 && now.getDate() < birth.getDate())) age--;
    83	  return age;
    84	}
    85	
    86	export function applyFilters(cases: PatientCase[], filters: CohortFilter): PatientCase[] {
