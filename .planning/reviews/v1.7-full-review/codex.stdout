   105	    await persistSettings(_cached);
   106	  } catch (err) {
   107	    console.error('[settingsService] Persist failed, reloading from server:', err);
   108	    await loadSettings();
   109	  }
   110	  return _cached!;
   111	}
   112	
   113	/**
   114	 * Reset all settings to defaults and persist.
   115	 * On server rejection, reloads settings to resync client cache.
   116	 */
   117	export async function resetSettings(): Promise<AppSettings> {
   118	  _cached = { ...DEFAULTS };
   119	  try {
   120	    await persistSettings(_cached);
   121	  } catch (err) {
   122	    console.error('[settingsService] Persist failed, reloading from server:', err);
   123	    await loadSettings();
   124	  }
   125	  return _cached!;
   126	}
   127	
   128	/**
   129	 * Export current settings as a YAML string for download.
   130	 */
   131	export function exportSettingsYaml(): string {
   132	  const settings = getSettings();
   133	  return yaml.dump(settings, { indent: 2, lineWidth: 120, noRefs: true });
   134	}

