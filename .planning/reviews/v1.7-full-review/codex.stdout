    68	      procedures: procedures.filter((p) => p.subject.reference === ref),
    69	      imagingStudies: imaging.filter((i) => i.subject.reference === ref),
    70	      medications: medications.filter((m) => m.subject.reference === ref),
    71	    };
    72	  });
