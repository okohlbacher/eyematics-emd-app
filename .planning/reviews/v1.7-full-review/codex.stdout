   129	                value={username}
   130	                onChange={(e) => setUsername(e.target.value)}
   131	                className="w-full px-3 py-2 border border-gray-300 dark:border-gray-600 dark:bg-gray-700 dark:text-gray-100 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none"
   132	                placeholder={t('loginUsernamePlaceholder')}
