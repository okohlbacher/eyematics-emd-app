   166	    const issuerOrigin = new URL(keycloakSection.issuer as string).origin;
   167	    connectSrc.push(issuerOrigin);
   168	  } catch { /* invalid URL — skip */ }
   169	}
   170	
   171	// Security headers (HSTS, CSP, X-Frame-Options, etc.)
   172	app.use(helmet({
   173	  contentSecurityPolicy: {
   174	    directives: {
   175	      defaultSrc: ["'self'"],
   176	      scriptSrc: ["'self'"],
   177	      styleSrc: ["'self'", "'unsafe-inline'"],
   178	      imgSrc: ["'self'", 'data:', 'blob:'],
   179	      connectSrc,
   180	      frameAncestors: ["'self'"],
   181	      baseUri: ["'self'"],
   182	    },
   183	  },
   184	  crossOriginEmbedderPolicy: false, // allow loading FHIR data
   185	}));
   186	
   187	// Body parsers — MUST be before auditMiddleware so req.body is populated for body capture
   188	// express.json() is scoped (NOT global) — issueApiHandler and settingsApiHandler use readBody()
   189	// on the raw stream and a global express.json() would consume the stream before them.
   190	app.use('/api/auth', express.json({ limit: '1mb' }));
   191	app.use('/api/data', express.json({ limit: '1mb' })); // before auditMiddleware (review concern #9)
   192	
   193	// Body parser scoped to the Phase 11 view-open beacon — MUST be before auditMiddleware
   194	// so req.body is populated when the handler runs. 16 KiB cap is a cheap DoS guard for
   195	// ad-hoc filter payloads.
   196	app.use('/api/audit/events/view-open', express.json({ limit: '16kb' }));
   197	
   198	// Phase 12 / D-15 / D-17 — Body parser + compression for aggregate route.
   199	// BEFORE auditMiddleware so req.body is populated (even though the middleware
   200	// skip-list short-circuits — defense in depth; see server/auditMiddleware.ts SKIP_AUDIT_PATHS).
   201	// Limit '16kb' matches Phase 11 precedent on /api/audit/events/view-open (CONTEXT §Established Patterns).
   202	app.use('/api/outcomes/aggregate', express.json({ limit: '16kb' }));
   203	app.use('/api/outcomes/aggregate', compression());
   204	
   205	// auditMiddleware BEFORE authMiddleware — captures 401 responses with user='anonymous'
   206	// (req.auth is read at res.finish time, so it resolves correctly for both 200 and 401)
   207	app.use('/api', auditMiddleware);
   208	
   209	// authMiddleware validates JWT on /api/* except public auth paths
   210	app.use('/api', authMiddleware);
   211	
   212	// Auth routes — login, verify, config (express.json already mounted above)
   213	app.use('/api/auth', authApiRouter);
   214	
   215	// Issue and settings routers (H-01: refactored from raw handlers to Express Router)
   216	app.use('/api/issues', express.json({ limit: '10mb' }), issueApiRouter);
   217	app.use('/api/settings', express.text({ limit: '1mb', type: '*/*' }), settingsApiRouter);
   218	
   219	// Audit query routes — /api/audit and /api/audit/export (admin-only export)
   220	app.use('/api/audit', auditApiRouter);

