 succeeded in 0ms:
     1	/**
     2	 * Auth API router: POST /login, POST /verify, GET /config
     3	 *
     4	 * Implements two-step login with optional 2FA.
     5	 * Rate limiting: per-username in-memory Map with exponential backoff.
     6	 * OTP: fixed configurable code from settings.yaml — no otplib.
     7	 */
     8	
     9	import crypto from 'node:crypto';
    10	
    11	import bcrypt from 'bcryptjs';
    12	import type { Request, Response } from 'express';
    13	import { Router } from 'express';
    14	import jwt from 'jsonwebtoken';
    15	
    16	import type { AuthPayload } from './authMiddleware.js';
    17	import { getValidCenterIds } from './constants.js';
    18	import type { UserRecord } from './initAuth.js';
    19	import { getAuthConfig, getJwtSecret, loadUsers, modifyUsers } from './initAuth.js';
    20	import { getAuthProvider } from './keycloakAuth.js';
    21	import { createRateLimiter } from './rateLimiting.js';
    22	
    23	// ---------------------------------------------------------------------------
    24	// Constants for user CRUD validation
    25	// ---------------------------------------------------------------------------
    26	
    27	const VALID_ROLES = new Set(['admin', 'researcher', 'epidemiologist', 'clinician', 'data_manager', 'clinic_lead']);
    28	
    29	/**
    30	 * Generate a secure random password: 16 chars base64url = ~96 bits entropy.
    31	 * Used for both user creation (D-01) and password reset.
    32	 */
    33	function generateSecurePassword(length = 16): string {
    34	  return crypto.randomBytes(Math.ceil(length * 0.75))
    35	    .toString('base64url')
    36	    .slice(0, length);
    37	}
    38	
    39	// ---------------------------------------------------------------------------
    40	// Rate limiting state (in-memory, per username)
    41	// ---------------------------------------------------------------------------
    42	
    43	// Rate limiter -- lazy init because getAuthConfig() requires initAuth() to have run first.
    44	// Single instance shared by /login and /verify handlers (addresses Codex review concern).
    45	let _limiter: ReturnType<typeof createRateLimiter> | null = null;
    46	function limiter() {
    47	  if (!_limiter) {
    48	    _limiter = createRateLimiter(getAuthConfig().maxLoginAttempts);
    49	  }
    50	  return _limiter;
    51	}
    52	
    53	// ---------------------------------------------------------------------------
    54	// JWT helpers
    55	// ---------------------------------------------------------------------------
    56	
    57	/** Sign a full session JWT (10 min expiry per D-05). */
    58	function signSessionToken(username: string, role: string, centers: string[]): string {
    59	  const payload: Omit<AuthPayload, 'iat' | 'exp'> = {
    60	    sub: username,
    61	    preferred_username: username,
    62	    role,
    63	    centers,
    64	  };
    65	  return jwt.sign(payload, getJwtSecret(), { algorithm: 'HS256', expiresIn: '10m' });
    66	}
    67	
    68	/** Sign a challenge token for 2FA step 2 (2 min expiry, purpose='challenge'). */
    69	function signChallengeToken(username: string): string {
    70	  return jwt.sign(
    71	    { sub: username, purpose: 'challenge' },
    72	    getJwtSecret(),
    73	    { algorithm: 'HS256', expiresIn: '2m' },
    74	  );
    75	}
    76	
    77	// ---------------------------------------------------------------------------
    78	// Router
    79	// ---------------------------------------------------------------------------
    80	
    81	export const authApiRouter = Router();
    82	
    83	/**
    84	 * POST /login
    85	 *
    86	 * Step 1 of login. Validates bcrypt credentials.
    87	 * - If 2FA disabled: returns { token } (full session JWT)
    88	 * - If 2FA enabled: returns { challengeToken } (short-lived, purpose='challenge')
    89	 * - If account locked: returns 429 with retryAfterMs
    90	 * - On bad credentials: returns 401 with generic error (no username enumeration, T-02-05)
    91	 */
    92	authApiRouter.post('/login', async (req: Request, res: Response): Promise<void> => {
    93	  // D-04: Local login disabled in Keycloak mode
    94	  if (getAuthProvider() === 'keycloak') {
    95	    res.status(405).json({
    96	      error: 'Local login is disabled. This instance uses Keycloak SSO. Contact your administrator.',
    97	    });
    98	    return;
    99	  }
   100	
   101	  const { username, password } = req.body as { username?: string; password?: string };
   102	
   103	  if (typeof username !== 'string' || typeof password !== 'string' || !username || !password) {
   104	    res.status(400).json({ error: 'username and password are required' });
   105	    return;
   106	  }
   107	
   108	  const key = username.toLowerCase();
   109	  const state = limiter().getLockState(key);
   110	
   111	  // Check lock before any credential lookup
   112	  if (limiter().isLocked(state)) {
   113	    const retryAfterMs = state.lockedUntil - Date.now();
   114	    res.status(429).json({ error: 'Account locked', retryAfterMs });
   115	    return;
   116	  }
   117	
   118	  // Find user (case-insensitive)
   119	  const users = loadUsers();
   120	  const user = users.find((u) => u.username.toLowerCase() === key);
   121	
   122	  if (!user || !user.passwordHash) {
   123	    // Record failure even for unknown users (prevent timing-based enumeration)
   124	    limiter().recordFailure(key);
   125	    res.status(401).json({ error: 'Invalid credentials' });
   126	    return;
   127	  }
   128	
   129	  // Verify password
   130	  const valid = await bcrypt.compare(password, user.passwordHash);
   131	  if (!valid) {
   132	    const newState = limiter().recordFailure(key);
   133	    if (limiter().isLocked(newState)) {
   134	      const retryAfterMs = newState.lockedUntil - Date.now();
   135	      res.status(429).json({ error: 'Account locked', retryAfterMs });
   136	      return;
   137	    }
   138	    res.status(401).json({ error: 'Invalid credentials' });
   139	    return;
   140	  }
   141	
   142	  // Successful login — reset attempts
   143	  limiter().resetAttempts(key);
   144	
   145	  const { twoFactorEnabled } = getAuthConfig();
   146	
   147	  if (twoFactorEnabled) {
   148	    // Return short-lived challenge token for OTP step
   149	    const challengeToken = signChallengeToken(user.username);
   150	    res.json({ challengeToken });
   151	  } else {
   152	    // Return full session JWT directly — update lastLogin (H-12)
   153	    const token = signSessionToken(user.username, user.role, user.centers);
   154	    try {
