     1	/**
     2	 * Build Authorization header from the stored JWT session token.
     3	 * Returns { Authorization: 'Bearer <jwt>' } if a token exists, or empty object.
     4	 */
     5	export function getAuthHeaders(): Record<string, string> {
     6	  const token = sessionStorage.getItem('emd-token');
     7	  if (token) {
     8	    return { Authorization: `Bearer ${token}` };
     9	  }
    10	  return {};
    11	}
    12	
    13	/**
    14	 * Authenticated fetch wrapper with global 401 interception.
    15	 * On 401, clears the session and redirects to login.
    16	 * Use this instead of raw fetch() for all authenticated API calls.
    17	 */
    18	export async function authFetch(input: RequestInfo | URL, init?: RequestInit): Promise<Response> {
    19	  const headers = { ...getAuthHeaders(), ...(init?.headers as Record<string, string> ?? {}) };
    20	  const resp = await fetch(input, { ...init, headers });
    21	
    22	  if (resp.status === 401) {
    23	    sessionStorage.removeItem('emd-token');
    24	    // Only redirect if not already on the login page
    25	    if (!window.location.pathname.includes('/login')) {
    26	      window.location.href = '/login';
    27	    }
    28	  }
    29	
    30	  return resp;
    31	}

