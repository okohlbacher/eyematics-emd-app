    38	function resourcesOfType<T>(bundles: BundleLike[], type: string): T[] {
    39	  return bundles.flatMap((b) =>
    40	    b.entry
    41	      .filter((e) => e.resource.resourceType === type)
    42	      .map((e) => e.resource as unknown as T),
    43	  );
    44	}
