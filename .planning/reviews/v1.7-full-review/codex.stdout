    46	export function extractPatientCases(bundles: BundleLike[]): PatientCase[] {
    47	  const patients = resourcesOfType<Patient>(bundles, 'Patient');
    48	  const conditions = resourcesOfType<Condition>(bundles, 'Condition');
    49	  const observations = resourcesOfType<Observation>(bundles, 'Observation');
    50	  const procedures = resourcesOfType<Procedure>(bundles, 'Procedure');
    51	  const imaging = resourcesOfType<ImagingStudy>(bundles, 'ImagingStudy');
    52	  const medications = resourcesOfType<MedicationStatement>(bundles, 'MedicationStatement');
    53	  const orgs = resourcesOfType<Organization>(bundles, 'Organization');
    54	
