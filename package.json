{
  "name": "emd-app",
  "private": true,
  "version": "1.4.0",
  "description": "EyeMatics Clinical Demonstrator (EMD) — ophthalmological research data analysis dashboard",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "node --import tsx server/index.ts",
    "generate-bundles": "node --import tsx scripts/generate-all-bundles.ts",
    "test": "vitest run",
    "test:check-skips": "node scripts/check-skipped-tests.mjs",
    "test:ci": "npm run test:check-skips && npm test",
    "knip": "knip"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "html-to-image": "^1.11.13",
    "http-proxy-middleware": "^3.0.5",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^3.2.0",
    "lucide-react": "^1.9.0",
    "otplib": "^12.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.14.2",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@testing-library/react": "^16.3.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "knip": "^6.6.2",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "overrides": {
    "follow-redirects": "^1.16.0"
  }
}
